{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Phase 2 — Chunking Strategy Comparison\n",
    "\n",
    "Compare fixed-size, recursive, and semantic chunking on the same papers.\n",
    "Metrics: chunk count, avg chunk size, size distribution, and qualitative inspection."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, \"..\")\n",
    "\n",
    "from pathlib import Path\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "from src.ingestion.parser import parse_pdf\n",
    "from src.ingestion.chunker import chunk_elements, ChunkStrategy\n",
    "\n",
    "DATA_DIR = Path(\"../data/pdfs\")\n",
    "sample_pdf = next(DATA_DIR.glob(\"*.pdf\"))\n",
    "print(f\"Using: {sample_pdf.name}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "elements = parse_pdf(sample_pdf, extract_images=False)\n",
    "print(f\"Parsed {len(elements)} elements\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "CHUNK_SIZE = 300\n",
    "OVERLAP = 50\n",
    "\n",
    "results = {}\n",
    "for strategy in ChunkStrategy:\n",
    "    chunks = chunk_elements(\n",
    "        elements,\n",
    "        strategy=strategy,\n",
    "        chunk_size=CHUNK_SIZE,\n",
    "        overlap=OVERLAP,\n",
    "    )\n",
    "    sizes = [len(c.content.split()) for c in chunks]\n",
    "    results[strategy.value] = {\n",
    "        \"chunks\": chunks,\n",
    "        \"count\": len(chunks),\n",
    "        \"avg_words\": sum(sizes) / len(sizes) if sizes else 0,\n",
    "        \"min_words\": min(sizes) if sizes else 0,\n",
    "        \"max_words\": max(sizes) if sizes else 0,\n",
    "        \"sizes\": sizes,\n",
    "    }\n",
    "    print(f\"{strategy.value:12s} → {len(chunks)} chunks, avg {results[strategy.value]['avg_words']:.0f} words\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Summary table\n",
    "summary = pd.DataFrame([\n",
    "    {\n",
    "        \"strategy\": k,\n",
    "        \"count\": v[\"count\"],\n",
    "        \"avg_words\": round(v[\"avg_words\"], 1),\n",
    "        \"min_words\": v[\"min_words\"],\n",
    "        \"max_words\": v[\"max_words\"],\n",
    "    }\n",
    "    for k, v in results.items()\n",
    "])\n",
    "summary"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Size distribution\n",
    "fig, axes = plt.subplots(1, 3, figsize=(15, 4), sharey=True)\n",
    "for ax, (name, data) in zip(axes, results.items()):\n",
    "    ax.hist(data[\"sizes\"], bins=30, color=\"steelblue\", edgecolor=\"white\")\n",
    "    ax.set_title(name)\n",
    "    ax.set_xlabel(\"chunk size (words)\")\n",
    "    ax.set_ylabel(\"count\")\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Qualitative inspection — same section, different strategies\n",
    "section_filter = \"results\"\n",
    "\n",
    "for strategy, data in results.items():\n",
    "    matching = [\n",
    "        c for c in data[\"chunks\"]\n",
    "        if section_filter.lower() in str(c.metadata.get(\"section\", \"\")).lower()\n",
    "    ]\n",
    "    print(f\"\\n=== {strategy} ({len(matching)} chunks in '{section_filter}') ===\")\n",
    "    for chunk in matching[:2]:\n",
    "        print(f\"  [{chunk.metadata.get('page')}] {chunk.content[:200]}\")\n",
    "        print()"
   ]
  }
 ],
